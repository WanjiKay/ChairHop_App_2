<% content_for :title, "Receipt — Booking ##{@appointment.id.to_s.rjust(6,'0')}" %>

<div class="container py-4 mt-5" style="max-width: 680px;" id="receipt-container">

  <%# Print-only header %>
  <div class="d-none d-print-block text-center mb-4">
    <h3 class="fw-bold">ChairHop</h3>
    <p class="text-muted mb-0">Booking Receipt</p>
  </div>

  <%# Screen header %>
  <div class="d-print-none d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Your Receipt</h4>
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-printer me-1"></i> Print
    </button>
  </div>

  <%# Booking reference banner %>
  <div class="alert alert-success d-flex justify-content-between align-items-center mb-4">
    <div>
      <strong>Booking Confirmed</strong>
      <small class="d-block text-muted">Booking #<%= @appointment.id.to_s.rjust(6, '0') %></small>
    </div>
    <span class="badge bg-success fs-6"><i class="bi bi-check-circle me-1"></i>Paid</span>
  </div>

  <%# Stylist info %>
  <div class="card shadow-sm mb-3">
    <div class="card-body d-flex align-items-center gap-3">
      <% if @appointment.stylist.avatar.attached? %>
        <%= image_tag url_for(@appointment.stylist.avatar),
              class: "rounded-circle",
              style: "width:56px;height:56px;object-fit:cover;" %>
      <% else %>
        <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold"
             style="width:56px;height:56px;font-size:1.2rem;">
          <%= @appointment.stylist.full_name.first&.upcase %>
        </div>
      <% end %>
      <div>
        <small class="text-muted d-block">Stylist</small>
        <strong><%= @appointment.stylist.full_name %></strong>
      </div>
    </div>
  </div>

  <%# Appointment details %>
  <div class="card shadow-sm mb-3">
    <div class="card-header bg-white"><h6 class="mb-0">Appointment Details</h6></div>
    <div class="card-body">
      <div class="row g-3">
        <% if @appointment.time.present? %>
          <div class="col-6">
            <small class="text-muted d-block">Date & Time</small>
            <strong><%= @appointment.time.strftime("%A, %b %-d at %-I:%M %p") %></strong>
          </div>
        <% end %>
        <% if @selected_service.present? %>
          <div class="col-6">
            <small class="text-muted d-block">Service</small>
            <strong><%= @selected_service %></strong>
          </div>
        <% end %>
        <div class="col-12">
          <small class="text-muted d-block">Location</small>
          <strong><%= @appointment.location_display %></strong>
        </div>
        <% if @appointment.appointment_add_ons.any? %>
          <div class="col-12">
            <small class="text-muted d-block">Add-ons</small>
            <% @appointment.appointment_add_ons.each do |add_on| %>
              <div class="d-flex justify-content-between">
                <span><%= add_on.service_name %></span>
                <span><%= number_to_currency(add_on.price) %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Payment breakdown %>
  <div class="card shadow-sm mb-3">
    <div class="card-header bg-white"><h6 class="mb-0">Payment Breakdown</h6></div>
    <div class="card-body">
      <div class="d-flex justify-content-between mb-1">
        <span>Service</span>
        <span><%= number_to_currency(@service_price - @add_ons_total) %></span>
      </div>
      <% if @add_ons_total > 0 %>
        <div class="d-flex justify-content-between mb-1">
          <span>Add-ons</span>
          <span><%= number_to_currency(@add_ons_total) %></span>
        </div>
      <% end %>
      <hr class="my-2">
      <div class="d-flex justify-content-between mb-1">
        <span>Total</span>
        <span><%= number_to_currency(@service_price) %></span>
      </div>
      <div class="d-flex justify-content-between mb-1">
        <span class="text-muted small">50% Deposit Paid Today</span>
        <span class="text-success"><%= number_to_currency(@deposit_paid) %></span>
      </div>
      <div class="d-flex justify-content-between fw-bold">
        <span>Balance Due at Completion</span>
        <span><%= number_to_currency(@balance_due) %></span>
      </div>
    </div>
  </div>

  <%# Transaction info %>
  <div class="card shadow-sm mb-4">
    <div class="card-header bg-white"><h6 class="mb-0">Transaction Details</h6></div>
    <div class="card-body">
      <% if @appointment.payment_id.present? %>
        <div class="mb-2">
          <small class="text-muted d-block">Transaction ID</small>
          <code class="small"><%= @appointment.payment_id %></code>
        </div>
      <% end %>
      <div class="mb-2">
        <small class="text-muted d-block">Payment Method</small>
        <span><i class="bi bi-credit-card me-1"></i>Card on file (Square)</span>
      </div>
      <div>
        <small class="text-muted d-block">Payment Status</small>
        <span class="badge bg-success">Deposit Paid</span>
      </div>
    </div>
  </div>

  <%# Actions — hidden on print %>
  <div class="d-print-none d-flex gap-2">
    <%= link_to my_appointments_path, class: "btn btn-primary" do %>
      <i class="bi bi-calendar-check me-1"></i> View My Appointments
    <% end %>
    <button onclick="window.print()" class="btn btn-outline-secondary">
      <i class="bi bi-printer me-1"></i> Print Receipt
    </button>
  </div>

</div>

<style>
  @media print {
    nav, footer, .d-print-none { display: none !important; }
    .card { border: 1px solid #dee2e6 !important; box-shadow: none !important; }
    body { font-size: 13px; }
  }
</style>
