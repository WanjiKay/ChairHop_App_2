<div class="container py-4">
  <h4 class="fw-bold mb-4">My Appointments</h4>

  <%# Bootstrap Tabs %>
  <ul class="nav nav-tabs mb-4" id="appointmentTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active" id="upcoming-tab" data-bs-toggle="tab"
              data-bs-target="#upcoming" type="button" role="tab">
        Upcoming
        <% if @upcoming.any? %>
          <span class="badge bg-primary ms-1"><%= @upcoming.count %></span>
        <% end %>
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="pending-tab" data-bs-toggle="tab"
              data-bs-target="#pending" type="button" role="tab">
        Pending
        <% if @pending.any? %>
          <span class="badge bg-warning text-dark ms-1"><%= @pending.count %></span>
        <% end %>
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="completed-tab" data-bs-toggle="tab"
              data-bs-target="#completed" type="button" role="tab">
        Completed
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link" id="cancelled-tab" data-bs-toggle="tab"
              data-bs-target="#cancelled" type="button" role="tab">
        Cancelled
      </button>
    </li>
  </ul>

  <div class="tab-content" id="appointmentTabsContent">

    <%# ── UPCOMING TAB ── %>
    <div class="tab-pane fade show active" id="upcoming" role="tabpanel">
      <% if @upcoming.any? %>
        <% @upcoming.each do |appointment| %>
          <%= render partial: "appointment_card",
                     locals: { appointment: appointment, card_type: :upcoming } %>
        <% end %>
      <% else %>
        <%= render partial: "appointments_empty_state",
                   locals: {
                     icon: "bi-calendar-check",
                     title: "No upcoming appointments",
                     message: "You don't have any confirmed appointments yet.",
                     link_path: stylists_path,
                     link_text: "Find a Stylist"
                   } %>
      <% end %>
    </div>

    <%# ── PENDING TAB ── %>
    <div class="tab-pane fade" id="pending" role="tabpanel">
      <% if @pending.any? %>
        <% @pending.each do |appointment| %>
          <%= render partial: "appointment_card",
                     locals: { appointment: appointment, card_type: :pending } %>
        <% end %>
      <% else %>
        <%= render partial: "appointments_empty_state",
                   locals: {
                     icon: "bi-hourglass-split",
                     title: "No pending requests",
                     message: "You don't have any appointments awaiting confirmation.",
                     link_path: stylists_path,
                     link_text: "Book an Appointment"
                   } %>
      <% end %>
    </div>

    <%# ── COMPLETED TAB ── %>
    <div class="tab-pane fade" id="completed" role="tabpanel">
      <% if @completed.any? %>
        <% @completed.each do |appointment| %>
          <%= render partial: "appointment_card",
                     locals: { appointment: appointment, card_type: :completed } %>
        <% end %>
      <% else %>
        <%= render partial: "appointments_empty_state",
                   locals: {
                     icon: "bi-check-circle",
                     title: "No completed appointments",
                     message: "Your completed appointments will appear here.",
                     link_path: stylists_path,
                     link_text: "Book an Appointment"
                   } %>
      <% end %>
    </div>

    <%# ── CANCELLED TAB ── %>
    <div class="tab-pane fade" id="cancelled" role="tabpanel">
      <% if @cancelled.any? %>
        <% @cancelled.each do |appointment| %>
          <%= render partial: "appointment_card",
                     locals: { appointment: appointment, card_type: :cancelled } %>
        <% end %>
      <% else %>
        <%= render partial: "appointments_empty_state",
                   locals: {
                     icon: "bi-x-circle",
                     title: "No cancelled appointments",
                     message: "You haven't cancelled any appointments.",
                     link_path: stylists_path,
                     link_text: "Book an Appointment"
                   } %>
      <% end %>
    </div>

  </div>
</div>
