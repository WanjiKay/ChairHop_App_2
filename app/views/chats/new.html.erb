<% content_for :title, "Chat with Hopps" %>

<div class="container py-5" style="max-width: 680px;">
  <div class="text-center mb-4">
    <%= image_tag "icons/favicon-96x96.png", height: 48, class: "mb-3 rounded-circle" %>
    <h1 class="fw-bold">Chat with Hopps</h1>
    <% if current_user.stylist? %>
      <p class="text-muted">Your AI assistant for managing your ChairHop business</p>
    <% else %>
      <p class="text-muted">Need help finding the perfect stylist? Chat with Hopps</p>
    <% end %>
  </div>

  <%= simple_form_for :message, url: chats_path do |f| %>
    <% if current_user.stylist? %>
      <p class="text-muted mb-3">Ask me anything about managing your profile,
      services, availability, or growing your business.</p>
    <% else %>
      <% if current_user.pro? %>
        <div class="mb-3">
          <p class="text-muted mb-3">
            Share a picture and let Hopps help you find a stylist
            <span class="badge ms-1"
                  style="background-color: #D8A7A7; font-size: 0.7rem;">
              ✨ Pro
            </span>
          </p>
          <%= f.input :photos,
                as: :file,
                label: "Upload your hair inspo (optional)",
                input_html: {
                  multiple: true,
                  accept: "image/png,image/jpeg,image/jpg,image/webp",
                  class: "form-control"
                } %>
        </div>
      <% else %>
        <div class="mb-3 p-3 rounded"
             style="background: #f9f0f0; border: 1px dashed #D8A7A7;">
          <p class="mb-1 small fw-semibold">
            ✨ Pro feature: Photo style matching
          </p>
          <p class="mb-0 small text-muted">
            Upload a hair inspiration photo and HOPPS will match you
            with the right stylist. Available on the Pro plan.
          </p>
        </div>
      <% end %>
    <% end %>

    <%= f.input :content,
          as: :text,
          label: false,
          input_html: {
            class: "form-control",
            rows: 3,
            placeholder: current_user.stylist? ?
              "E.g. How do I add a new service? or Write me a bio..." :
              "E.g. I'm looking for a stylist, or ask me anything..."
          } %>

    <% if current_user.stylist? %>
      <div class="d-flex gap-2 flex-wrap mb-3">
        <button type="button"
                class="btn btn-outline-secondary btn-sm hopps-suggestion"
                data-suggestion="Write me a professional bio for my profile">
          ✍️ Write my bio
        </button>
        <button type="button"
                class="btn btn-outline-secondary btn-sm hopps-suggestion"
                data-suggestion="How can I attract more clients this week?">
          📈 Grow my bookings
        </button>
        <button type="button"
                class="btn btn-outline-secondary btn-sm hopps-suggestion"
                data-suggestion="What are some tips for retaining clients?">
          💡 Client retention tips
        </button>
      </div>
    <% else %>
      <div class="d-flex gap-2 flex-wrap mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm hopps-suggestion"
          data-suggestion="I'm looking for a stylist, can you help me find one?">
          🌊 Find a stylist
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm hopps-suggestion"
          data-suggestion="What should I do to prepare for my appointment?">
          📋 Prep for my appointment
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm hopps-suggestion"
          data-suggestion="How do I reschedule an appointment?">
          🔄 Reschedule help
        </button>
      </div>
    <% end %>

    <%= f.submit "Chat with Hopps",
          class: "btn btn-primary px-4",
          data: { disable_with: "Starting chat..." } %>
  <% end %>

  <% content_for :page_scripts do %>
  <script>
    document.querySelectorAll(".hopps-suggestion").forEach(function(btn) {
      btn.addEventListener("click", function() {
        const textarea = document.querySelector("textarea");
        if (textarea) textarea.value = btn.dataset.suggestion;
      });
    });
  </script>
  <% end %>
</div>
