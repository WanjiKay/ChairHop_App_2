<%= form_with(model: [:stylist, @location], local: true) do |f| %>
  <% if @location.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @location.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Location Name", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "e.g., Downtown Studio, Home Salon" %>
    <small class="text-muted">Give this location a memorable name</small>
  </div>

  <div class="mb-3">
    <%= f.label :street_address, "Street Address", class: "form-label" %>
    <%= f.text_field :street_address, class: "form-control", placeholder: "123 Rue Sainte-Catherine" %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= f.label :city, class: "form-label" %>
      <%= f.text_field :city, class: "form-control", placeholder: "Montreal" %>
    </div>

    <div class="col-md-3 mb-3">
      <%= f.label :state, "Province", class: "form-label" %>
      <%= f.text_field :state, class: "form-control text-uppercase", placeholder: "QC", maxlength: 2 %>
    </div>

    <div class="col-md-3 mb-3">
      <%= f.label :zip_code, "Postal Code", class: "form-label" %>
      <%= f.text_field :zip_code, class: "form-control text-uppercase", placeholder: "H1A 2K6" %>
    </div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit "Save Location", class: "btn btn-primary" %>
    <%= link_to "Cancel", stylist_locations_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
