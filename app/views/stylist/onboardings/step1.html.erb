<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">

      <!-- Progress -->
      <div class="mb-4">
        <div class="d-flex justify-content-between mb-2">
          <span class="badge bg-primary">Step 1 of 4</span>
          <span class="text-muted">About You</span>
        </div>
        <div class="progress" style="height: 5px;">
          <div class="progress-bar" role="progressbar" style="width: 25%"></div>
        </div>
      </div>

      <div class="card shadow">
        <div class="card-body p-5">
          <h2 class="card-title mb-1">Welcome to ChairHop!</h2>
          <p class="text-muted mb-4">Let's set up your stylist profile</p>

          <%= form_with model: @user, url: complete_step1_stylist_onboarding_path, method: :post, local: true, multipart: true do |f| %>

            <% if @user.errors.any? %>
              <div class="alert alert-danger">
                <ul class="mb-0">
                  <% @user.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <!-- Avatar -->
            <div class="mb-4">
              <%= f.label :avatar, "Profile Photo", class: 'form-label fw-bold' %>
              <% if @user.avatar.attached? %>
                <div class="mb-2">
                  <%= image_tag @user.avatar, class: 'rounded-circle', style: 'width: 80px; height: 80px; object-fit: cover;' %>
                </div>
              <% end %>
              <%= f.file_field :avatar, class: 'form-control', accept: 'image/*' %>
              <small class="text-muted">Optional — JPG, PNG, or GIF. Max 5 MB.</small>
            </div>

            <!-- Bio -->
            <div class="mb-4">
              <%= f.label :about, "Bio / About You *", class: 'form-label fw-bold' %>
              <p class="text-muted small mb-2">Tell customers about your experience and specialties (minimum 50 characters)</p>
              <%= f.text_area :about,
                    class: 'form-control',
                    rows: 5,
                    maxlength: 500,
                    placeholder: "Example: I'm a licensed hairstylist with 8 years of experience specializing in color treatments and modern cuts...",
                    required: true %>
              <small class="text-muted">
                <span id="char-count">0</span> / 500 characters
                <span id="min-warning" class="text-danger ms-2" style="display: none;">Minimum 50 characters required</span>
              </small>
            </div>

            <div class="d-grid">
              <%= f.submit "Continue to Services →", class: "btn btn-primary btn-lg" %>
            </div>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</div>

<script>
  document.addEventListener('turbo:load', function () {
    const textarea = document.querySelector('textarea[name="user[about]"]');
    const charCount = document.getElementById('char-count');
    const minWarning = document.getElementById('min-warning');
    if (!textarea) return;

    function update() {
      const len = textarea.value.length;
      charCount.textContent = len;
      minWarning.style.display = len > 0 && len < 50 ? 'inline' : 'none';
    }

    textarea.addEventListener('input', update);
    update();
  });
</script>
