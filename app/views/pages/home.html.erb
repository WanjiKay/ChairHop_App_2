<div class="home-page mt-5">

  <!-- HERO SECTION -->
  <section class="hero-section">
    <div class="hero-image-wrapper">
      <div class="hero-image-wrapper">
    <%= image_tag "HeroCover.png", class: "hero-image" %>

    <h1 class="hero-title">Our chairs are always open</h1>

    <div class="hero-cta mt-3 d-flex gap-2 justify-content-center">
      <% unless user_signed_in? %>
        <%= link_to "Sign In", new_user_session_path, class: "btn btn-outline-light btn-lg" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-outline-light btn-lg" %>
      <% end %>
    </div>
  </section>

  <!-- SEARCH SECTION -->
  <div class="search-section p-4 rounded position-relative mt-3 mb-4">
    <div class="d-flex flex-column gap-2">

      <%= form_with url: stylists_path, method: :get, local: true, class: "d-flex flex-column gap-2" do |f| %>
        <%= f.text_field :search, class: "form-control", placeholder: "Search by stylist name or location" %>
        <%= f.submit "Search", class: "btn btn-primary px-4" %>
      <% end %>

    </div>
  </div>

  <!-- USER APPOINTMENTS LINK -->
  <% if defined?(user_signed_in?) && user_signed_in? && current_user.customer? %>
    <div class="mb-3 text-start">
      <%= link_to my_appointments_path, class: "btn btn-primary" do %>
        My Appointments
      <% end %>
    </div>

  <% end %>

  <!-- AVAILABLE STYLISTS SECTION -->
  <% if @available_stylists.any? %>
    <h2 class="section-title text-center mb-3">Stylists Available Now</h2>

    <div class="row g-3 justify-content-center">
      <% @available_stylists.each do |stylist| %>
        <div class="col-md-4 col-sm-6">
          <%= link_to stylist_path(stylist), class: "text-decoration-none" do %>
            <div class="card appointment-card text-center p-3">
              <% if stylist.avatar.attached? %>
                <%= image_tag url_for(stylist.avatar), class: "rounded-circle mx-auto mb-2", style: "width:80px;height:80px;object-fit:cover;border:3px solid #4A5D4F;" %>
              <% else %>
                <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mx-auto mb-2"
                     style="width:80px;height:80px;color:white;font-size:1.5rem;">
                  <%= stylist.name&.first&.upcase || "S" %>
                </div>
              <% end %>
              <h6 class="fw-bold mb-1"><%= stylist.name %></h6>
              <p class="text-muted small mb-2"><%= stylist.location_display.presence || short_address(stylist) %></p>
              <span class="badge bg-success"><i class="fas fa-circle me-1" style="font-size:0.6em;"></i>Available</span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="text-center mt-4 d-flex gap-2 justify-content-center">
      <%= link_to "Browse All Stylists", stylists_path, class: "btn btn-primary" %>
      <%= link_to "Browse Availability", appointments_path, class: "btn btn-outline-primary" %>
    </div>
  <% else %>
    <p class="text-center mt-4 text-muted">No stylists available right now — check back soon.</p>
  <% end %>

</div>
