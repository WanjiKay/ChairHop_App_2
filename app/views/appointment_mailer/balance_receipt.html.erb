<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; }
    .header { background: #198754; color: white; padding: 24px; text-align: center; }
    .header h2 { margin: 0; }
    .body { padding: 24px; }
    .detail-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eee; font-size: 14px; }
    .detail-row:last-child { border-bottom: none; }
    .card { border: 1px solid #dee2e6; border-radius: 6px; padding: 16px; margin: 16px 0; }
    .alert-success { background: #d1e7dd; border: 1px solid #a3cfbb; border-radius: 6px; padding: 12px 16px; margin: 16px 0; font-size: 14px; }
    .btn { display: inline-block; background: #198754; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold; margin-top: 16px; }
    .footer { background: #f8f9fa; padding: 16px; text-align: center; font-size: 12px; color: #6c757d; margin-top: 24px; }
  </style>
</head>
<body>
  <div class="header">
    <h2>Balance Receipt</h2>
    <p style="margin:8px 0 0; opacity:0.9;">Your remaining balance has been charged</p>
  </div>
  <div class="body">
    <p>Hi <%= @customer.name %>,</p>
    <p>The remaining balance for your appointment with <strong><%= @stylist.name %></strong> has been charged. Here is your receipt.</p>

    <div class="alert-success">
      <strong>Payment successful</strong> &mdash; <%= number_to_currency(@balance_paid) %> charged to your card on file.
    </div>

    <div class="card">
      <div class="detail-row"><span>Stylist</span><strong><%= @stylist.name %></strong></div>
      <% if @selected_service.present? %>
        <div class="detail-row"><span>Service</span><strong><%= @selected_service %></strong></div>
      <% end %>
      <% if @appointment.appointment_add_ons.any? %>
        <div class="detail-row"><span>Add-ons</span><strong><%= @appointment.appointment_add_ons.map(&:service_name).join(", ") %></strong></div>
      <% end %>
      <div class="detail-row"><span>Date &amp; Time</span><strong><%= format_datetime(@appointment.time) %></strong></div>
      <% if @appointment.location.present? %>
        <div class="detail-row"><span>Location</span><strong><%= @appointment.location.name %></strong></div>
      <% end %>
      <div class="detail-row"><span>Balance Charged</span><strong><%= number_to_currency(@balance_paid) %></strong></div>
      <% if @balance_payment_id.present? %>
        <div class="detail-row"><span>Transaction ID</span><code style="font-size:12px;"><%= @balance_payment_id %></code></div>
      <% end %>
      <% if @appointment.completed_at.present? %>
        <div class="detail-row"><span>Date Charged</span><strong><%= @appointment.completed_at.strftime("%B %-d, %Y at %-I:%M %p") %></strong></div>
      <% end %>
      <div class="detail-row"><span>Booking #</span><strong>#<%= @appointment.id.to_s.rjust(6, "0") %></strong></div>
    </div>

    <a href="<%= balance_receipt_appointment_url(@appointment) %>" class="btn">View Full Receipt</a>
  </div>
  <div class="footer">&copy; ChairHop &middot; You're receiving this because you have an account with us.</div>
</body>
</html>
