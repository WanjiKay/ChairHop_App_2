<!DOCTYPE html>
<html>
<head>
  <style>
    body { font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: 0 auto; }
    .header { background: #198754; color: white; padding: 24px; text-align: center; }
    .header h2 { margin: 0; }
    .body { padding: 24px; }
    .detail-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid #eee; font-size: 14px; }
    .detail-row:last-child { border-bottom: none; }
    .card { border: 1px solid #dee2e6; border-radius: 6px; padding: 16px; margin: 16px 0; }
    .alert-success { background: #d1e7dd; border: 1px solid #a3cfbb; border-radius: 6px; padding: 12px 16px; margin: 16px 0; }
    .btn { display: inline-block; background: #198754; color: white; padding: 12px 24px; text-decoration: none; border-radius: 6px; font-weight: bold; margin-top: 16px; }
    .footer { background: #f8f9fa; padding: 16px; text-align: center; font-size: 12px; color: #6c757d; margin-top: 24px; }
  </style>
</head>
<body>
  <div class="header">
    <h2>Balance Payment Received</h2>
    <p style="margin:8px 0 0; opacity:0.9;">Appointment marked as complete</p>
  </div>
  <div class="body">
    <p>Hi <%= @stylist.name %>,</p>
    <p>The remaining balance for <strong><%= @customer.name %></strong>'s appointment has been successfully charged. The appointment is now marked as complete.</p>

    <div class="alert-success">
      <strong>Payment successful</strong> &mdash; Balance collected via card on file.
    </div>

    <div class="card">
      <div class="detail-row"><span>Customer</span><strong><%= @customer.name %></strong></div>
      <% if @appointment.selected_service.present? %>
        <div class="detail-row"><span>Service</span><strong><%= @appointment.selected_service %></strong></div>
      <% end %>
      <div class="detail-row"><span>Date &amp; Time</span><strong><%= format_datetime(@appointment.time) %></strong></div>
      <% if @appointment.payment_amount.present? %>
        <div class="detail-row"><span>Deposit Collected</span><strong><%= number_to_currency(@appointment.payment_amount.to_f * 0.5) %></strong></div>
        <div class="detail-row"><span>Balance Collected</span><strong><%= number_to_currency(@appointment.payment_amount.to_f * 0.5) %></strong></div>
        <div class="detail-row"><span>Total</span><strong><%= number_to_currency(@appointment.payment_amount.to_f) %></strong></div>
      <% end %>
      <div class="detail-row"><span>Booking #</span><strong>#<%= @appointment.id.to_s.rjust(6, "0") %></strong></div>
    </div>

    <a href="<%= appointment_url(@appointment) %>" class="btn">View Appointment</a>
  </div>
  <div class="footer">&copy; ChairHop &middot; You're receiving this because you have a stylist account with us.</div>
</body>
</html>
