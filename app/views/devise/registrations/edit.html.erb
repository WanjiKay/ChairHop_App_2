<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5">
      <div class="card shadow devise-card">
        <div class="card-body p-4">
          <h2 class="card-title text-center mb-4">Account Settings</h2>

          <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
            <%= f.error_notification %>

            <h6 class="fw-bold mb-3">Email Address</h6>
            <div class="mb-3">
              <%= f.input :email, required: true, autofocus: true,
                          input_html: { class: 'form-control' } %>

              <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                <p>Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
              <% end %>
            </div>

            <h6 class="fw-bold mb-3 mt-4">Change Password</h6>
            <div class="mb-3">
              <%= f.input :password,
                          hint: "leave it blank if you don't want to change it",
                          required: false,
                          input_html: { class: 'form-control', autocomplete: "new-password" } %>
              <%= f.input :password_confirmation,
                          required: false,
                          input_html: { class: 'form-control', autocomplete: "new-password" } %>
              <%= f.input :current_password,
                          hint: "we need your current password to confirm your changes",
                          required: true,
                          input_html: { class: 'form-control', autocomplete: "current-password" } %>
            </div>

            <div class="d-grid mt-3">
              <%= f.submit "Update", class: "btn btn-primary btn-lg w-100" %>
            </div>
          <% end %>

          <hr class="my-4">
          <p class="text-muted small fw-bold mb-3">Close My Account</p>
          <%= button_to "Close My Account", registration_path(resource_name),
                data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" },
                method: :delete,
                class: "btn btn-sm btn-outline-danger" %>

          <div class="mt-3">
            <%= link_to "← Back", :back, class: "text-muted small" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
