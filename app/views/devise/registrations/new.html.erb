<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5">
      <div class="card shadow devise-card">
        <div class="card-body p-5" data-controller="password-validator email-check">
          <h2 class="card-title text-center mb-4">Join ChairHop</h2>

          <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= f.error_notification %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <!-- Role Selection -->
            <div class="mb-4">
              <label class="form-label fw-bold">I want to:</label>

              <div class="form-check mb-2">
                <%= f.radio_button :role, 'customer', class: 'form-check-input', checked: resource.role.blank? || resource.customer?, id: 'role_customer' %>
                <label class="form-check-label" for="role_customer">Book appointments <span class="text-muted">(Customer)</span></label>
              </div>

              <div class="form-check">
                <%= f.radio_button :role, 'stylist', class: 'form-check-input', id: 'role_stylist' %>
                <label class="form-check-label" for="role_stylist">Accept bookings <span class="text-muted">(Stylist)</span></label>
              </div>
            </div>

            <!-- Name -->
            <div class="mb-3">
              <div class="row g-2">
                <div class="col">
                  <label class="form-label">First name</label>
                  <%= f.text_field :first_name, class: 'form-control', placeholder: 'First name', required: true %>
                </div>
                <div class="col">
                  <label class="form-label">Last name</label>
                  <%= f.text_field :last_name, class: 'form-control', placeholder: 'Last name', required: true %>
                </div>
              </div>
            </div>

            <!-- Email -->
            <div class="mb-3">
              <%= f.label :email, class: 'form-label' %>
              <%= f.email_field :email,
                    autocomplete: "email",
                    class: 'form-control',
                    placeholder: 'Enter your email',
                    required: true,
                    data: {
                      email_check_target: 'field',
                      action: 'blur->email-check#check'
                    } %>
              <div class="invalid-feedback">This email is already registered.</div>
            </div>

            <!-- Password -->
            <div class="mb-3">
              <%= f.label :password, class: 'form-label' %>
              <% if @minimum_password_length %>
                <small class="text-muted d-block mb-1"><%= @minimum_password_length %> characters minimum</small>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", class: 'form-control', placeholder: 'Create a password', required: true, data: { password_validator_target: 'password', action: 'input->password-validator#validate' } %>
              <div class="password-requirements mt-2" id="password-requirements">
                <p class="req-item" id="req-length" data-password-validator-target="reqLength">At least 8 characters</p>
                <p class="req-item" id="req-number" data-password-validator-target="reqNumber">At least one number</p>
                <p class="req-item" id="req-special" data-password-validator-target="reqSpecial">At least one special character (!@#$%^&*)</p>
              </div>
            </div>

            <!-- Password Confirmation -->
            <div class="mb-4">
              <%= f.label :password_confirmation, "Confirm Password", class: 'form-label' %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: 'form-control', placeholder: 'Confirm your password', required: true, data: { password_validator_target: 'confirmation', action: 'input->password-validator#validateMatch' } %>
              <p class="req-item" id="req-match" data-password-validator-target="reqMatch">Passwords match</p>
            </div>

            <!-- Terms of Service -->
            <div class="form-check mt-3">
              <%= f.check_box :tos_accepted_at,
                  { class: "form-check-input", required: true },
                  Time.current.to_s,
                  nil %>
              <label class="form-check-label" for="user_tos_accepted_at">
                I agree to the <a href="/terms" target="_blank">Terms of Service</a>
                and <a href="/privacy" target="_blank">Privacy Policy</a>
              </label>
            </div>

            <!-- Submit -->
            <div class="d-grid mt-3">
              <%= f.submit "Create Account", class: "btn btn-primary btn-lg w-100",
                    data: { email_check_target: 'submit' } %>
            </div>
          <% end %>

          <div class="devise-links mt-4">
            <a href="/users/sign_in">Already have an account? Log in</a>
          </div>

        </div>

        <!-- Email already taken modal -->
        <div class="modal fade" id="emailTakenModal" tabindex="-1" aria-labelledby="emailTakenModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header border-0">
                <h5 class="modal-title" id="emailTakenModalLabel">Email already in use</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <p>An account with this email address already exists. Would you like to reset your password or use a different email?</p>
              </div>
              <div class="modal-footer border-0">
                <a href="/users/password/new" class="btn btn-primary">Reset password</a>
                <button type="button" class="btn btn-outline-secondary"
                        data-action="click->email-check#useDifferentEmail">
                  Use a different email
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
