<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-5">
      <div class="card shadow devise-card">
        <div class="card-body p-4">
          <h2 class="mb-4 text-center">Log in</h2>

          <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <div class="form-inputs">
              <%= f.input :email,
                          required: false,
                          autofocus: true,
                          input_html: { autocomplete: "email" } %>
              <%= f.input :password,
                          required: false,
                          input_html: { autocomplete: "current-password" } %>
              <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
            </div>

            <div class="form-actions mt-4">
              <%= f.submit "Log in", class: "btn btn-primary btn-lg w-100 mt-3" %>
            </div>
          <% end %>

          <div class="mt-3 text-center">
            <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-muted small d-block mb-3" %>
            <a href="/users/sign_up" class="btn btn-primary btn-lg w-100 mt-2">Create an account</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
