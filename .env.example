# ChairHop Environment Variables
# Copy this file to .env and fill in your actual values

# Application Domain
DOMAIN=localhost:3000

# Square — OAuth & Payments
SQUARE_APPLICATION_ID=
SQUARE_APPLICATION_SECRET=
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_OAUTH_REDIRECT_URI=http://localhost:3000/square/callback
# Get webhook signature key from:
# Square Developer Dashboard → Your App → Webhooks → Signature key
SQUARE_WEBHOOK_SIGNATURE_KEY=your_webhook_signature_key_from_square_dashboard

# Mapbox — geocoding / maps
MAPBOX_API_KEY=

# Cloudinary — image storage (signed uploads; no upload preset needed)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rails — required in production
RAILS_MASTER_KEY=
